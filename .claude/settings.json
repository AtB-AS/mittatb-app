{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/env/**)",
      "Read(**/.netrc)",
      "Read(**/*.key)",
      "Read(**/*.plist)",
      "Read(**/google-services.json)",
      "Read(**/*.xcconfig)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {"ENABLE_LSP_TOOL": "1"}
}
