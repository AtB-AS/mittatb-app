{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(pwd:*)",
      "Bash(realpath:*)",
      
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh search prs:*)",

      "Bash(yarn lint:*)",
      "Bash(yarn tsc:*)",
      "Bash(yarn prettier:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/env/**)",
      "Read(**/.netrc)",
      "Read(**/*.key)",
      "Read(**/*.plist)",
      "Read(**/google-services.json)",
      "Read(**/*.xcconfig)"
    ]
  }
}