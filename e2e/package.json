{
  "name": "atb-e2e",
  "version": "1.85.0",
  "private": true,
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "test:android": "APP_ENV=staging wdio ./conf/android.conf.ts",
    "test:android:smoke": "APP_ENV=staging wdio ./conf/android.conf.ts --spec test/specs/smoke.e2e.ts",
    "test:android:local:dev": "APP_ENV=debug IS_LOCAL=true wdio ./conf/android.conf.local.dev.ts",
    "test:android:local:firebase": "APP_ENV=staging IS_LOCAL=true wdio ./conf/android.conf.local.firebase.ts",
    "test:android:local:perfMeasure": "flashlight test --bundleId no.mittatb.debug --testCommand \"APP_ENV=debug yarn test:android:local:dev --spec test/flashlight/performanceMeasures.e2e.ts\" --resultsTitle performanceMeasures --iterationCount 1 --maxRetries 1"
  },
  "devDependencies": {
    "@perf-profiler/reporter": "0.9.0",
    "@perf-profiler/types": "0.8.0",
    "@wdio/appium-service": "9.27.0",
    "@wdio/cli": "9.27.0",
    "@wdio/globals": "9.27.0",
    "@wdio/junit-reporter": "9.27.0",
    "@wdio/local-runner": "9.27.0",
    "@wdio/mocha-framework": "9.27.0",
    "@wdio/spec-reporter": "9.27.0",
    "@wdio/visual-service": "9.2.2",
    "appium": "3.3.0",
    "appium-inspector-plugin": "2026.2.1",
    "appium-uiautomator2-driver": "7.1.2",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.4",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "^5.1.6",
    "wdio-mochawesome-reporter": "7.0.0",
    "wdio-performancetotal-service": "4.0.7",
    "wdio-wait-for": "3.1.1"
  }
}
